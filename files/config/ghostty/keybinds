# clear default keybinds
keybind = "clear"

keybind = "ctrl+space=toggle_split_zoom"
keybind = "ctrl+up=jump_to_prompt:-1"
keybind = "ctrl+down=jump_to_prompt:1"

keybind = "ctrl+shift+a=select_all"
keybind = "ctrl+shift+c=copy_to_clipboard"
keybind = "ctrl+shift+v=paste_from_clipboard"
keybind = "ctrl+shift+n=new_window"
keybind = "ctrl+shift+t=new_tab"
keybind = "ctrl+shift+w=close_tab"
keybind = "ctrl+shift+q=quit"
keybind = "ctrl+shift+tab=toggle_tab_overview"
keybind = "ctrl+shift+space=toggle_fullscreen"

keybind = "ctrl+a>i=inspector:toggle"
keybind = "ctrl+a>h=goto_split:left"
keybind = "ctrl+a>j=goto_split:down"
keybind = "ctrl+a>k=goto_split:up"
keybind = "ctrl+a>l=goto_split:right"
keybind = "ctrl+a>o=goto_split:next"
keybind = "ctrl+a>semicolon=goto_split:previous"
keybind = "ctrl+a>n=next_tab"
keybind = "ctrl+a>p=previous_tab"
keybind = "ctrl+a>r=reset"

keybind = "ctrl+a>shift+h=new_split:left"
keybind = "ctrl+a>shift+j=new_split:down"
keybind = "ctrl+a>shift+k=new_split:up"
keybind = "ctrl+a>shift+l=new_split:right"

keybind = "unconsumed:ctrl+d=scroll_page_down"
keybind = "unconsumed:ctrl+u=scroll_page_up"
keybind = "unconsumed:alt+h=resize_split:left,10"
keybind = "unconsumed:alt+j=resize_split:down,10"
keybind = "unconsumed:alt+k=resize_split:up,10"
keybind = "unconsumed:alt+l=resize_split:right,10"
keybind = "unconsumed:alt+equal=equalize_splits"
keybind = "unconsumed:alt+e=equalize_splits"
keybind = "unconsumed:alt+plus=increase_font_size:1"
keybind = "unconsumed:alt+minus=decrease_font_size:1"
keybind = "unconsumed:alt+0=reset_font_size"
keybind = "unconsumed:alt+r=reload_config"

